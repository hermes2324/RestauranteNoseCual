<Shell
    x:Class="RestauranteNoseCual.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:RestauranteNoseCual.View"
    FlyoutBehavior="Flyout"
    FlyoutWidth="280"
    Shell.NavBarIsVisible="True"
    Shell.TabBarIsVisible="False">

    <Shell.FlyoutContent>
        <views:FlyoutMenuPage />
    </Shell.FlyoutContent>

  
    <FlyoutItem Title="Inicio" FlyoutDisplayOptions="AsMultipleItems">
        <ShellContent
            Title="Inicio"
            ContentTemplate="{DataTemplate views:Pantalla_Principal}"
            Route="Pantalla_Principal" />
    </FlyoutItem>

</Shell>