<?xml version="1.0" encoding="utf-8" ?>
<FlyoutPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            xmlns:local="clr-namespace:RestauranteNoseCual.View"
            x:Class="RestauranteNoseCual.View.Pantalla_Principal"
            Title="Restaurante">

    <FlyoutPage.Flyout>
        <local:FlyoutMenuPage x:Name="flyoutPage"/>
    </FlyoutPage.Flyout>

    <FlyoutPage.Detail>
        <NavigationPage BarBackgroundColor="#0D0D0D" BarTextColor="#F5C842">
            <x:Arguments>
                <ContentPage Title=" " BackgroundColor="#0D0D0D">
                    <ScrollView>
                        <VerticalStackLayout Spacing="0">

                            <!-- HEADER SALUDO -->
                            <Grid BackgroundColor="#111111"
                                  Padding="20,48,20,20"
                                  ColumnDefinitions="*,Auto">

                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                    <Label x:Name="LblSaludo"
                                           Text="¡Hola! 👋"
                                           TextColor="#888888"
                                           FontSize="13"/>
                                    <Label x:Name="LblNombreUsuario"
                                           Text="..."
                                           TextColor="White"
                                           FontSize="22"
                                           FontAttributes="Bold"/>
                                    <Label Text="¿Qué se te antoja hoy?"
                                           TextColor="#F5C842"
                                           FontSize="13"/>
                                </VerticalStackLayout>

                                <!-- Avatar -->
                                <Border Grid.Column="1"
                                        BackgroundColor="#F5C842"
                                        StrokeShape="RoundRectangle 28"
                                        HeightRequest="52"
                                        WidthRequest="52"
                                        Stroke="Transparent"
                                        VerticalOptions="Center">
                                    <Label x:Name="LblAvatar"
                                           Text="U"
                                           TextColor="#0D0D0D"
                                           FontSize="22"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                            </Grid>

                            <!-- BARRA DE BÚSQUEDA -->
                            <Border BackgroundColor="#1A1A1A"
                                    Stroke="#2A2A2A"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 16"
                                    Margin="20,16,20,0"
                                    Padding="16,0"
                                    HeightRequest="50">
                                <Grid ColumnDefinitions="Auto,*">
                                    <Label Grid.Column="0"
                                           Text="🔍"
                                           FontSize="16"
                                           VerticalOptions="Center"
                                           Margin="0,0,10,0"/>
                                    <Entry Grid.Column="1"
                                           Placeholder="Buscar hamburguesas, alitas..."
                                           PlaceholderColor="#555555"
                                           TextColor="White"
                                           BackgroundColor="Transparent"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </Border>

                            <!-- BANNER PROMOCIONAL -->
                            <Border BackgroundColor="#1A1A1A"
                                    StrokeShape="RoundRectangle 20"
                                    Stroke="Transparent"
                                    Margin="20,16,20,0"
                                    HeightRequest="160">
                                <Grid>
                                    <BoxView Color="#F5C842" Opacity="0.08"/>
                                    <Grid ColumnDefinitions="*,Auto" Padding="24,20">
                                        <VerticalStackLayout Grid.Column="0"
                                                             Spacing="6"
                                                             VerticalOptions="Center">
                                            <Border BackgroundColor="#F5C842"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="8,4"
                                                    HorizontalOptions="Start"
                                                    Stroke="Transparent">
                                                <Label Text="🔥 OFERTA DEL DÍA"
                                                       TextColor="#0D0D0D"
                                                       FontSize="10"
                                                       FontAttributes="Bold"
                                                       CharacterSpacing="1"/>
                                            </Border>
                                            <Label Text="Combo Smash&#10;+ Refresco"
                                                   TextColor="White"
                                                   FontSize="22"
                                                   FontAttributes="Bold"
                                                   LineHeight="1.1"/>
                                            <Label Text="Solo por hoy $149"
                                                   TextColor="#F5C842"
                                                   FontSize="14"
                                                   FontAttributes="Bold"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1"
                                               Text="🍔"
                                               FontSize="80"
                                               VerticalOptions="Center"
                                               Margin="0,0,8,0"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- CATEGORÍAS -->
                            <VerticalStackLayout Padding="20,24,20,0" Spacing="14">
                                <Label Text="CATEGORÍAS"
                                       TextColor="#888888"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       CharacterSpacing="2"/>

                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">

                                    <!-- Hamburguesas -->
                                    <Border Grid.Column="0"
                                            StrokeShape="RoundRectangle 20"
                                            Stroke="Transparent"
                                            BackgroundColor="#1E1E1E"
                                            Padding="0">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnCategoriaClicked"
                                      CommandParameter="Hamburguesa"/>
                                        </Border.GestureRecognizers>
                                        <Grid RowDefinitions="110,Auto,Auto">
                                            <!-- Imagen ocupa todo el tope -->
                                            <Border Grid.Row="0"
                                                    StrokeShape="RoundRectangle 20,20,0,0"
                                                    Stroke="Transparent"
                                                    BackgroundColor="#2A2A2A">
                                                <Image Source="https://c0.klipartz.com/pngpicture/203/765/gratis-png-hamburguesa-con-verduras-hamburguesa-deslizante-hamburguesa-hamburguesa.png"
                                                       Aspect="AspectFill"
                                                       HeightRequest="110"/>    
                                            </Border>
                                            <Label Grid.Row="1"
                                                   Text="Hamburguesas"
                                                   TextColor="White"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="Center"
                                                   HorizontalTextAlignment="Center"
                                                   Margin="8,10,8,2"/>
                                            <Label Grid.Row="2"
                                                   x:Name="LblCountHamb"
                                                   Text="..."
                                                   TextColor="#F5C842"
                                                   FontSize="10"
                                                   HorizontalOptions="Center"
                                                   Margin="0,0,0,12"/>
                                        </Grid>
                                    </Border>

                                    <!-- Alitas -->
                                    <Border Grid.Column="1"
                                            StrokeShape="RoundRectangle 20"
                                            Stroke="#F5C842"
                                            StrokeThickness="2"
                                            BackgroundColor="#1E1E1E"
                                            Padding="0">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnCategoriaClicked"
                                      CommandParameter="Alita"/>
                                        </Border.GestureRecognizers>
                                        <Grid RowDefinitions="110,Auto,Auto">
                                            <Border Grid.Row="0"
                                                    StrokeShape="RoundRectangle 18,18,0,0"
                                                    Stroke="Transparent"
                                                    BackgroundColor="#2A2A2A">
                                                <Image Source="https://www.sondemesa.com/web/image/344497-00a81b8a/alitas.png"
                                                       Aspect="AspectFill"
                                                       HeightRequest="110"/>    
                                            </Border>
                                            <!-- Badge popular -->
                                            <Border Grid.Row="0"
                                                    BackgroundColor="#F5C842"
                                                    StrokeShape="RoundRectangle 8"
                                                    Stroke="Transparent"
                                                    Padding="6,3"
                                                    HorizontalOptions="End"
                                                    VerticalOptions="Start"
                                                    Margin="0,8,8,0">
                                                <Label Text="🔥 TOP"
                                                       TextColor="#0D0D0D"
                                                       FontSize="9"
                                                       FontAttributes="Bold"/>
                                            </Border>
                                            <Label Grid.Row="1"
                                                   Text="Alitas"
                                                   TextColor="White"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="Center"
                                                   Margin="8,10,8,2"/>
                                            <Label Grid.Row="2"
                                                   x:Name="LblCountAlit"
                                                   Text="..."
                                                   TextColor="#F5C842"
                                                   FontSize="10"
                                                   HorizontalOptions="Center"
                                                   Margin="0,0,0,12"/>
                                        </Grid>
                                    </Border>

                                    <!-- Boneles -->
                                    <Border Grid.Column="2"
                                            StrokeShape="RoundRectangle 20"
                                            Stroke="Transparent"
                                            BackgroundColor="#1E1E1E"
                                            Padding="0">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnCategoriaClicked"
                                      CommandParameter="Boneles"/>
                                        </Border.GestureRecognizers>
                                        <Grid RowDefinitions="110,Auto,Auto">
                                            <Border Grid.Row="0"
                                                    StrokeShape="RoundRectangle 20,20,0,0"
                                                    Stroke="Transparent"
                                                     BackgroundColor="#2A2A2A">
                                                <Image Source="https://dam.cocinafacil.com.mx/wp-content/uploads/2020/04/Boneless-bbq.jpg"
                                                       Aspect="AspectFill"
                                                       HeightRequest="110"/>    
                                            </Border>
                                            <Label Grid.Row="1"
                                                   Text="Boneles"
                                                   TextColor="White"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="Center"
                                                   Margin="8,10,8,2"/>
                                            <Label Grid.Row="2"
                                                   x:Name="LblCountBon"
                                                   Text="..."
                                                   TextColor="#F5C842"
                                                   FontSize="10"
                                                   HorizontalOptions="Center"
                                                   Margin="0,0,0,12"/>
                                        </Grid>
                                    </Border>

                                </Grid>
                            </VerticalStackLayout>

                            <!-- LO MÁS PEDIDO -->
                            <VerticalStackLayout Padding="20,24,20,32" Spacing="14">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0"
                                           Text="⭐ LO MÁS PEDIDO"
                                           TextColor="#888888"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           CharacterSpacing="2"
                                           VerticalOptions="Center"/>
                                    <Label Grid.Column="1"
                                           Text="Ver todo →"
                                           TextColor="#F5C842"
                                           FontSize="12"
                                           VerticalOptions="Center">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnVerTodoClicked"/>
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>

                                <!-- ✅ CollectionView con datos reales -->
                                <CollectionView x:Name="ListaMasPedido"
                                                SelectionMode="None">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Border BackgroundColor="#1A1A1A"
                                                    StrokeShape="RoundRectangle 16"
                                                    Stroke="#2A2A2A"
                                                    StrokeThickness="1"
                                                    Margin="0,0,0,12">
                                                <Grid ColumnDefinitions="90,*"
                                                      HeightRequest="90">
                                                    <!-- Imagen real de Supabase -->
                                                    <Border Grid.Column="0"
                                                            BackgroundColor="#262626"
                                                            StrokeShape="RoundRectangle 16,0,0,16"
                                                            Stroke="Transparent">
                                                        <Image Source="{Binding Fotografia}"
                                                               Aspect="AspectFill"
                                                               HeightRequest="90"
                                                               WidthRequest="90"/>
                                                    </Border>
                                                    <VerticalStackLayout Grid.Column="1"
                                                                         Padding="14,0"
                                                                         Spacing="3"
                                                                         VerticalOptions="Center">
                                                        <Label Text="{Binding Nombre}"
                                                               TextColor="White"
                                                               FontSize="14"
                                                               FontAttributes="Bold"/>
                                                        <Label Text="{Binding Descripcion}"
                                                               TextColor="#666666"
                                                               FontSize="11"
                                                               MaxLines="2"
                                                               LineBreakMode="TailTruncation"/>
                                                        <Label Text="{Binding Precio, StringFormat='${0:F2}'}"
                                                               TextColor="#F5C842"
                                                               FontSize="15"
                                                               FontAttributes="Bold"
                                                               Margin="0,4,0,0"/>
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>

                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </ScrollView>
                </ContentPage>
            </x:Arguments>
        </NavigationPage>
    </FlyoutPage.Detail>
</FlyoutPage>