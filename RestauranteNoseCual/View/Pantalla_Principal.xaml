<?xml version="1.0" encoding="utf-8" ?>
<FlyoutPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            xmlns:local="clr-namespace:RestauranteNoseCual.View"
            x:Class="RestauranteNoseCual.View.Pantalla_Principal"
            Title="Restaurante">

    <FlyoutPage.Flyout>
        <local:FlyoutMenuPage x:Name="flyoutPage"/>
    </FlyoutPage.Flyout>

    <FlyoutPage.Detail>
        <NavigationPage BarBackgroundColor="#0D0D0D" BarTextColor="#F5C842">
            <x:Arguments>
                <ContentPage Title=" " BackgroundColor="#0D0D0D">
                    <ScrollView>
                        <VerticalStackLayout Spacing="0">

                            <!-- ══════════════════════════════ -->
                            <!--         HEADER SALUDO         -->
                            <!-- ══════════════════════════════ -->
                            <Grid BackgroundColor="#111111"
                                  Padding="20,48,20,20"
                                  ColumnDefinitions="*,Auto">

                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                    <Label Text="¡Buenas noches! 👋"
                                           TextColor="#888888"
                                           FontSize="13"/>
                                    <Label x:Name="LblNombreUsuario"
                                           Text="Cargando..."
                                           TextColor="White"
                                           FontSize="22"
                                           FontAttributes="Bold"/>
                                    <Label Text="¿Qué se te antoja hoy?"
                                           TextColor="#F5C842"
                                           FontSize="13"/>
                                </VerticalStackLayout>

                                <!-- Avatar -->
                                <Border Grid.Column="1"
                                        BackgroundColor="#F5C842"
                                        StrokeShape="RoundRectangle 28"
                                        HeightRequest="52"
                                        WidthRequest="52"
                                        Stroke="Transparent"
                                        VerticalOptions="Center">
                                    <Label x:Name="LblAvatar"
                                           Text="U"
                                           TextColor="#0D0D0D"
                                           FontSize="22"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                            </Grid>

                            <!-- ══════════════════════════════ -->
                            <!--       BARRA DE BÚSQUEDA       -->
                            <!-- ══════════════════════════════ -->
                            <Border BackgroundColor="#1A1A1A"
                                    Stroke="#2A2A2A"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 16"
                                    Margin="20,0,20,0"
                                    Padding="16,0"
                                    HeightRequest="50">
                                <Grid ColumnDefinitions="Auto,*">
                                    <Label Grid.Column="0"
                                           Text="🔍"
                                           FontSize="16"
                                           VerticalOptions="Center"
                                           Margin="0,0,10,0"/>
                                    <Entry Grid.Column="1"
                                           Placeholder="Buscar hamburguesas, alitas..."
                                           PlaceholderColor="#555555"
                                           TextColor="White"
                                           BackgroundColor="Transparent"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </Border>

                            <!-- ══════════════════════════════ -->
                            <!--       BANNER PROMOCIONAL      -->
                            <!-- ══════════════════════════════ -->
                            <Border BackgroundColor="#1A1A1A"
                                    StrokeShape="RoundRectangle 20"
                                    Stroke="Transparent"
                                    Margin="20,20,20,0"
                                    Padding="0"
                                    HeightRequest="160">
                                <Grid>
                                    <!-- Fondo degradado simulado -->
                                    <BoxView Color="#1A1A1A"/>
                                    <BoxView Color="#F5C842"
                                             Opacity="0.08"/>

                                    <Grid ColumnDefinitions="*,Auto"
                                          Padding="24,20">
                                        <VerticalStackLayout Grid.Column="0"
                                                             Spacing="6"
                                                             VerticalOptions="Center">
                                            <Border BackgroundColor="#F5C842"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="8,4"
                                                    HorizontalOptions="Start"
                                                    Stroke="Transparent">
                                                <Label Text="🔥 OFERTA DEL DÍA"
                                                       TextColor="#0D0D0D"
                                                       FontSize="10"
                                                       FontAttributes="Bold"
                                                       CharacterSpacing="1"/>
                                            </Border>
                                            <Label Text="Combo Smash&#10;+ Refresco"
                                                   TextColor="White"
                                                   FontSize="22"
                                                   FontAttributes="Bold"
                                                   LineHeight="1.1"/>
                                            <Label Text="Solo por hoy $149"
                                                   TextColor="#F5C842"
                                                   FontSize="14"
                                                   FontAttributes="Bold"/>
                                        </VerticalStackLayout>

                                        <!-- Emoji grande decorativo -->
                                        <Label Grid.Column="1"
                                               Text="🍔"
                                               FontSize="80"
                                               VerticalOptions="Center"
                                               Margin="0,0,8,0"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- ══════════════════════════════ -->
                            <!--          CATEGORÍAS           -->
                            <!-- ══════════════════════════════ -->
                            <VerticalStackLayout Padding="20,24,20,0" Spacing="14">
                                <Label Text="CATEGORÍAS"
                                       TextColor="#888888"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       CharacterSpacing="2"/>

                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">

                                    <!-- Hamburguesas -->
                                    <Border Grid.Column="0"
                                            StrokeShape="RoundRectangle 18"
                                            Stroke="Transparent"
                                            BackgroundColor="#1E1E1E"
                                            Padding="10,18">
                                        <VerticalStackLayout Spacing="8">
                                            <Label Text="🍔"
                                                   FontSize="36"
                                                   HorizontalOptions="Center"/>
                                            <Label Text="Hamber-&#10;guesas"
                                                   TextColor="White"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="Center"
                                                   HorizontalTextAlignment="Center"/>
                                            <Label Text="12 items"
                                                   TextColor="#666666"
                                                   FontSize="10"
                                                   HorizontalOptions="Center"/>
                                        </VerticalStackLayout>
                                    </Border>

                                    <!-- Alitas — resaltada -->
                                    <Border Grid.Column="1"
                                            StrokeShape="RoundRectangle 18"
                                            Stroke="Transparent"
                                            BackgroundColor="#F5C842"
                                            Padding="10,18">
                                        <VerticalStackLayout Spacing="8">
                                            <Label Text="🍗"
                                                   FontSize="36"
                                                   HorizontalOptions="Center"/>
                                            <Label Text="Alitas"
                                                   TextColor="#0D0D0D"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="Center"/>
                                            <Label Text="8 items"
                                                   TextColor="#333333"
                                                   FontSize="10"
                                                   HorizontalOptions="Center"/>
                                        </VerticalStackLayout>
                                    </Border>

                                    <!-- Boneles -->
                                    <Border Grid.Column="2"
                                            StrokeShape="RoundRectangle 18"
                                            Stroke="Transparent"
                                            BackgroundColor="#1E1E1E"
                                            Padding="10,18">
                                        <VerticalStackLayout Spacing="8">
                                            <Label Text="🍖"
                                                   FontSize="36"
                                                   HorizontalOptions="Center"/>
                                            <Label Text="Boneles"
                                                   TextColor="White"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="Center"/>
                                            <Label Text="10 items"
                                                   TextColor="#666666"
                                                   FontSize="10"
                                                   HorizontalOptions="Center"/>
                                        </VerticalStackLayout>
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>

                            <!-- ══════════════════════════════ -->
                            <!--        LO MÁS PEDIDO          -->
                            <!-- ══════════════════════════════ -->
                            <VerticalStackLayout Padding="20,24,20,32" Spacing="14">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0"
                                           Text="⭐ LO MÁS PEDIDO"
                                           TextColor="#888888"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           CharacterSpacing="2"
                                           VerticalOptions="Center"/>
                                    <Label Grid.Column="1"
                                           Text="Ver todo →"
                                           TextColor="#F5C842"
                                           FontSize="12"
                                           VerticalOptions="Center"/>
                                </Grid>

                                <!-- Card 1 -->
                                <Border BackgroundColor="#1A1A1A"
                                        StrokeShape="RoundRectangle 16"
                                        Stroke="#2A2A2A"
                                        StrokeThickness="1">
                                    <Grid ColumnDefinitions="90,*,Auto"
                                          Padding="0,0,16,0"
                                          HeightRequest="90">
                                        <Border Grid.Column="0"
                                                BackgroundColor="#262626"
                                                StrokeShape="RoundRectangle 16,0,0,16"
                                                Stroke="Transparent">
                                            <Label Text="🍔" FontSize="40"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1"
                                                             Padding="14,0"
                                                             Spacing="3"
                                                             VerticalOptions="Center">
                                            <Label Text="Smash Burger Clásica"
                                                   TextColor="White"
                                                   FontSize="14"
                                                   FontAttributes="Bold"/>
                                            <Label Text="Doble carne · queso · salsa especial"
                                                   TextColor="#666666"
                                                   FontSize="11"/>
                                            <Label Text="$129"
                                                   TextColor="#F5C842"
                                                   FontSize="15"
                                                   FontAttributes="Bold"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2"
                                               Text="+"
                                               TextColor="#0D0D0D"
                                               BackgroundColor="#F5C842"
                                               FontSize="22"
                                               FontAttributes="Bold"
                                               WidthRequest="36"
                                               HeightRequest="36"
                                               HorizontalTextAlignment="Center"
                                               VerticalOptions="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Card 2 -->
                                <Border BackgroundColor="#1A1A1A"
                                        StrokeShape="RoundRectangle 16"
                                        Stroke="#2A2A2A"
                                        StrokeThickness="1">
                                    <Grid ColumnDefinitions="90,*,Auto"
                                          Padding="0,0,16,0"
                                          HeightRequest="90">
                                        <Border Grid.Column="0"
                                                BackgroundColor="#262626"
                                                StrokeShape="RoundRectangle 16,0,0,16"
                                                Stroke="Transparent">
                                            <Label Text="🍗" FontSize="40"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1"
                                                             Padding="14,0"
                                                             Spacing="3"
                                                             VerticalOptions="Center">
                                            <Label Text="Alitas BBQ x10"
                                                   TextColor="White"
                                                   FontSize="14"
                                                   FontAttributes="Bold"/>
                                            <Label Text="Salsa BBQ ahumada · ranch incluido"
                                                   TextColor="#666666"
                                                   FontSize="11"/>
                                            <Label Text="$149"
                                                   TextColor="#F5C842"
                                                   FontSize="15"
                                                   FontAttributes="Bold"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2"
                                               Text="+"
                                               TextColor="#0D0D0D"
                                               BackgroundColor="#F5C842"
                                               FontSize="22"
                                               FontAttributes="Bold"
                                               WidthRequest="36"
                                               HeightRequest="36"
                                               HorizontalTextAlignment="Center"
                                               VerticalOptions="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Card 3 -->
                                <Border BackgroundColor="#1A1A1A"
                                        StrokeShape="RoundRectangle 16"
                                        Stroke="#2A2A2A"
                                        StrokeThickness="1">
                                    <Grid ColumnDefinitions="90,*,Auto"
                                          Padding="0,0,16,0"
                                          HeightRequest="90">
                                        <Border Grid.Column="0"
                                                BackgroundColor="#262626"
                                                StrokeShape="RoundRectangle 16,0,0,16"
                                                Stroke="Transparent">
                                            <Label Text="🍖" FontSize="40"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1"
                                                             Padding="14,0"
                                                             Spacing="3"
                                                             VerticalOptions="Center">
                                            <Label Text="Boneles Picosos x12"
                                                   TextColor="White"
                                                   FontSize="14"
                                                   FontAttributes="Bold"/>
                                            <Label Text="Empanizados · salsa buffalo"
                                                   TextColor="#666666"
                                                   FontSize="11"/>
                                            <Label Text="$139"
                                                   TextColor="#F5C842"
                                                   FontSize="15"
                                                   FontAttributes="Bold"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2"
                                               Text="+"
                                               TextColor="#0D0D0D"
                                               BackgroundColor="#F5C842"
                                               FontSize="22"
                                               FontAttributes="Bold"
                                               WidthRequest="36"
                                               HeightRequest="36"
                                               HorizontalTextAlignment="Center"
                                               VerticalOptions="Center"/>
                                    </Grid>
                                </Border>

                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </ScrollView>
                </ContentPage>
            </x:Arguments>
        </NavigationPage>
    </FlyoutPage.Detail>
</FlyoutPage>