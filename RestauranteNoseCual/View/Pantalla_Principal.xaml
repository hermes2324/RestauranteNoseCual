<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RestauranteNoseCual.View.Pantalla_Principal"
             BackgroundColor="#0D0D0D"
             Title="Inicio">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <Grid BackgroundColor="#111111"
                  Padding="20,48,20,20"
                  ColumnDefinitions="*,Auto">

                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <Label x:Name="LblSaludo"
                           Text="¡Hola! 👋"
                           TextColor="#888888"
                           FontSize="13"/>
                    <Label x:Name="LblNombreUsuario"
                           Text="..."
                           TextColor="White"
                           FontSize="22"
                           FontAttributes="Bold"/>
                    <Label Text="¿Qué se te antoja hoy?"
                           TextColor="#F5C842"
                           FontSize="13"/>
                </VerticalStackLayout>

                <Border Grid.Column="1"
                        BackgroundColor="#F5C842"
                        StrokeShape="RoundRectangle 28"
                        HeightRequest="52"
                        WidthRequest="52"
                        Stroke="Transparent"
                        VerticalOptions="Center">
                    <Label x:Name="LblAvatar"
                           Text="U"
                           TextColor="#0D0D0D"
                           FontSize="22"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>
            </Grid>

            <Border BackgroundColor="#1A1A1A"
                    Stroke="#2A2A2A"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    Margin="20,16,20,0"
                    Padding="16,0"
                    HeightRequest="50">
                <Grid ColumnDefinitions="Auto,*">
                    <Label Grid.Column="0"
                           Text="🔍"
                           FontSize="16"
                           VerticalOptions="Center"
                           Margin="0,0,10,0"/>
                    <Entry Grid.Column="1"
                           Placeholder="Buscar hamburguesas, alitas..."
                           PlaceholderColor="#555555"
                           TextColor="White"
                           BackgroundColor="Transparent"
                           VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- Carrusel de combos dinámico -->
            <CarouselView x:Name="CarruselCombos"
              Margin="20,16,20,0"
              HeightRequest="160"
              Loop="True"
              PeekAreaInsets="0">
                <CarouselView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#1A1A1A"
                    StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    Margin="0,0,8,0">
                            <Grid>
                                <BoxView Color="#F5C842" Opacity="0.08"/>
                                <Grid ColumnDefinitions="*,130" Padding="24,20">

                                    <VerticalStackLayout Grid.Column="0" Spacing="6"
                                             VerticalOptions="Center">
                                        <Border BackgroundColor="#F5C842"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="8,4" HorizontalOptions="Start">
                                            <Label Text="🔥 OFERTA DEL DÍA"
                                       TextColor="#0D0D0D"
                                       FontSize="10" FontAttributes="Bold"/>
                                        </Border>
                                        <Label Text="{Binding Nombre}"
                                   TextColor="White" FontSize="20"
                                   FontAttributes="Bold" LineHeight="1.1"
                                   MaxLines="2" LineBreakMode="TailTruncation"/>
                                        <Label Text="{Binding Precio, StringFormat='Solo por hoy ${0:F2}'}"
                                   TextColor="Yellow" FontSize="14"
                                   FontAttributes="Bold"/>
                                    </VerticalStackLayout>

                                    <!-- Imagen real del combo -->
                                    <Border Grid.Column="1"
                                StrokeShape="RoundRectangle 16"
                                Stroke="Transparent"
                                BackgroundColor="#2A2A2A"
                                Margin="0,8,0,8">
                                        <Image Source="{Binding Fotografia}"
                                   Aspect="AspectFill"/>
                                    </Border>

                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>

            <!-- Indicador de puntos -->
            <IndicatorView x:Name="IndicadorCombos"
               HorizontalOptions="Center"
               IndicatorColor="#333333"
               SelectedIndicatorColor="#F5C842"
               IndicatorSize="7"
               Margin="0,8,0,0"/>

            <VerticalStackLayout Padding="20,24,20,0" Spacing="14">
                <Label Text="CATEGORÍAS" TextColor="#888888" FontSize="12" FontAttributes="Bold" CharacterSpacing="2"/>
                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                    <Border Grid.Column="0" StrokeShape="RoundRectangle 20" Stroke="Transparent" BackgroundColor="#1E1E1E">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoriaClicked" CommandParameter="Hamburguesa"/>
                        </Border.GestureRecognizers>
                        <Grid RowDefinitions="110,Auto,Auto">
                            <Border Grid.Row="0" StrokeShape="RoundRectangle 20,20,0,0" BackgroundColor="#2A2A2A">
                                <Image Source="https://c0.klipartz.com/pngpicture/203/765/gratis-png-hamburguesa-con-verduras-hamburguesa-deslizante-hamburguesa-hamburguesa.png" Aspect="AspectFill" HeightRequest="110"/>
                            </Border>
                            <Label Grid.Row="1" Text="Hamburguesas" TextColor="White" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" Margin="8,10,8,2"/>
                            <Label Grid.Row="2" x:Name="LblCountHamb" Text="..." TextColor="#F5C842" FontSize="10" HorizontalOptions="Center" Margin="0,0,0,12"/>
                        </Grid>
                    </Border>
                    <Border Grid.Column="1" StrokeShape="RoundRectangle 20" Stroke="#F5C842" StrokeThickness="2" BackgroundColor="#1E1E1E">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoriaClicked" CommandParameter="Alita"/>
                        </Border.GestureRecognizers>
                        <Grid RowDefinitions="110,Auto,Auto">
                            <Border Grid.Row="0" StrokeShape="RoundRectangle 18,18,0,0" BackgroundColor="#2A2A2A">
                                <Image Source="https://www.sondemesa.com/web/image/344497-00a81b8a/alitas.png" Aspect="AspectFill" HeightRequest="110"/>
                            </Border>
                            <Label Grid.Row="1" Text="Alitas" TextColor="White" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" Margin="8,10,8,2"/>
                            <Label Grid.Row="2" x:Name="LblCountAlit" Text="..." TextColor="#F5C842" FontSize="10" HorizontalOptions="Center" Margin="0,0,0,12"/>
                        </Grid>
                    </Border>
                    <Border Grid.Column="2" StrokeShape="RoundRectangle 20" Stroke="Transparent" BackgroundColor="#1E1E1E">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoriaClicked" CommandParameter="Boneles"/>
                        </Border.GestureRecognizers>
                        <Grid RowDefinitions="110,Auto,Auto">
                            <Border Grid.Row="0" StrokeShape="RoundRectangle 20,20,0,0" BackgroundColor="#2A2A2A">
                                <Image Source="https://dam.cocinafacil.com.mx/wp-content/uploads/2020/04/Boneless-bbq.jpg" Aspect="AspectFill" HeightRequest="110"/>
                            </Border>
                            <Label Grid.Row="1" Text="Boneles" TextColor="White" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" Margin="8,10,8,2"/>
                            <Label Grid.Row="2" x:Name="LblCountBon" Text="..." TextColor="#F5C842" FontSize="10" HorizontalOptions="Center" Margin="0,0,0,12"/>
                        </Grid>
                    </Border>
                    <Border Grid.Column="3" StrokeShape="RoundRectangle 20" Stroke="Transparent" BackgroundColor="#1E1E1E">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCategoriaClicked" CommandParameter="Bebidas"/>
                        </Border.GestureRecognizers>
                        <Grid RowDefinitions="110,Auto,Auto">
                            <Border Grid.Row="0" StrokeShape="RoundRectangle 20,20,0,0" BackgroundColor="#2A2A2A">
                                <Image Source="https://enlacocinamagazine.b-cdn.net/wp-content/uploads/2018/07/granizados.jpg" Aspect="AspectFill" HeightRequest="110"/>
                            </Border>
                            <Label Grid.Row="1" Text="Bebidas" TextColor="White" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" Margin="8,10,8,2"/>
                            <Label Grid.Row="2" x:Name="LblCountBebi" Text="..." TextColor="#F5C842" FontSize="10" HorizontalOptions="Center" Margin="0,0,0,12"/>
                        </Grid>
                    </Border>
                </Grid>
            </VerticalStackLayout>

            <VerticalStackLayout Padding="20,24,20,32" Spacing="14">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="⭐ LO MÁS PEDIDO" TextColor="#888888" FontSize="12" FontAttributes="Bold" CharacterSpacing="2" VerticalOptions="Center"/>
                    <Label Grid.Column="1" Text="Ver todo →" TextColor="#F5C842" FontSize="12" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnVerTodoClicked"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <CollectionView x:Name="ListaMasPedido" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#1A1A1A" StrokeShape="RoundRectangle 16" Stroke="#2A2A2A" StrokeThickness="1" Margin="0,0,0,12">
                                <Grid ColumnDefinitions="90,*" HeightRequest="90">
                                    <Border Grid.Column="0" BackgroundColor="#262626" StrokeShape="RoundRectangle 16,0,0,16" Stroke="Transparent">
                                        <Image Source="{Binding Fotografia}" Aspect="AspectFill" HeightRequest="90" WidthRequest="90"/>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Padding="14,0" Spacing="3" VerticalOptions="Center">
                                        <Label Text="{Binding Nombre}" TextColor="White" FontSize="14" FontAttributes="Bold"/>
                                        <Label Text="{Binding Descripcion}" TextColor="#666666" FontSize="11" MaxLines="2" LineBreakMode="TailTruncation"/>
                                        <Label Text="{Binding Precio, StringFormat='${0:F2}'}" TextColor="#F5C842" FontSize="15" FontAttributes="Bold" Margin="0,4,0,0"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>