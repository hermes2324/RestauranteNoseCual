<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:syncfusion="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
             x:Class="RestauranteNoseCual.View.MisPedidosPage"
             BackgroundColor="#0D0D0D"
             Title="Mis Órdenes">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0"
                BackgroundColor="#111111"
                Stroke="Transparent"
                Padding="20,48,20,16">
            <Label Text="📜 Mis Órdenes"
                   TextColor="White"
                   FontSize="22"
                   FontAttributes="Bold"/>
        </Border>

        <!-- SfDataGrid -->
        <Grid Grid.Row="1" RowDefinitions="*,Auto" Margin="16,8,16,16">

            <syncfusion:SfDataGrid x:Name="GridOrdenes"
                                   Grid.Row="0"
                                   AutoGenerateColumnsMode="None"
                                   GridLinesVisibility="Horizontal"
                                   HeaderGridLinesVisibility="Horizontal"
                                   BackgroundColor="#1A1A1A"
                                   SelectionMode="Single"
                                   NavigationMode="Row"
                                   CellTapped="OnOrdenTapped">

                <syncfusion:SfDataGrid.DefaultStyle>
                    <syncfusion:DataGridStyle
                        HeaderRowBackground="#111111"
                        HeaderRowTextColor="#F5C842"
                        GridLineColor="#2A2A2A"
                        SelectionBackground="#2A2A2A"/>
                </syncfusion:SfDataGrid.DefaultStyle>

                <syncfusion:SfDataGrid.Columns>

                    <syncfusion:DataGridTextColumn MappingName="Id"
                                                   HeaderText="Orden"
                                                   Width="70">
                        <syncfusion:DataGridTextColumn.CellStyle>
                            <Style TargetType="syncfusion:DataGridCell">
                                <Setter Property="TextColor" Value="White"/>
                                <Setter Property="FontAttributes" Value="Bold"/>
                            </Style>
                        </syncfusion:DataGridTextColumn.CellStyle>
                    </syncfusion:DataGridTextColumn>

                    <syncfusion:DataGridTextColumn MappingName="FechaHora"
                                                   HeaderText="Fecha"
                                                   Format="dd/MM/yy"
                                                   Width="90">
                        <syncfusion:DataGridTextColumn.CellStyle>
                            <Style TargetType="syncfusion:DataGridCell">
                                <Setter Property="TextColor" Value="#888888"/>
                            </Style>
                        </syncfusion:DataGridTextColumn.CellStyle>
                    </syncfusion:DataGridTextColumn>

                    <syncfusion:DataGridTextColumn MappingName="TipoEntrega"
                                                   HeaderText="Tipo"
                                                   Width="90">
                        <syncfusion:DataGridTextColumn.CellStyle>
                            <Style TargetType="syncfusion:DataGridCell">
                                <Setter Property="TextColor" Value="White"/>
                            </Style>
                        </syncfusion:DataGridTextColumn.CellStyle>
                    </syncfusion:DataGridTextColumn>

                    <syncfusion:DataGridTextColumn MappingName="Estado"
                                                   HeaderText="Estado"
                                                   Width="100">
                        <syncfusion:DataGridTextColumn.CellStyle>
                            <Style TargetType="syncfusion:DataGridCell">
                                <Setter Property="TextColor" Value="#F5C842"/>
                                <Setter Property="FontAttributes" Value="Bold"/>
                            </Style>
                        </syncfusion:DataGridTextColumn.CellStyle>
                    </syncfusion:DataGridTextColumn>

                    <syncfusion:DataGridNumericColumn MappingName="Total"
                                                      HeaderText="Total"
                                                      Format="C2"
                                                      Width="100">
                        <syncfusion:DataGridNumericColumn.CellStyle>
                            <Style TargetType="syncfusion:DataGridCell">
                                <Setter Property="TextColor" Value="#F5C842"/>
                                <Setter Property="FontAttributes" Value="Bold"/>
                            </Style>
                        </syncfusion:DataGridNumericColumn.CellStyle>
                    </syncfusion:DataGridNumericColumn>

                </syncfusion:SfDataGrid.Columns>
            </syncfusion:SfDataGrid>

            <!-- Empty view manual -->
            <VerticalStackLayout x:Name="PanelVacio"
                                 Grid.Row="0"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="12"
                                 IsVisible="False">
                <Label Text="🍽️" FontSize="48" HorizontalOptions="Center"/>
                <Label Text="Aún no tienes órdenes"
                       TextColor="#555555" FontSize="15"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Toca una fila para ver detalle -->
            <Label Grid.Row="1"
                   Text="Toca una orden para ver el detalle"
                   TextColor="#444444"
                   FontSize="11"
                   HorizontalOptions="Center"
                   Margin="0,8,0,0"/>

        </Grid>
    </Grid>
</ContentPage>