<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:syncfusion="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
             x:Class="RestauranteNoseCual.View.Pedidos"
             Title="Historial de Pedidos"
             BackgroundColor="#121212">

    <Grid RowDefinitions="Auto, *">
        <Label Text="MIS PEDIDOS" 
               TextColor="#F5C842" 
               FontSize="24" 
               FontAttributes="Bold" 
               HorizontalOptions="Center" 
               Margin="20" />

        <syncfusion:SfDataGrid x:Name="GridPedidos"
                       AutoGenerateColumnsMode="None"
                       HeaderGridLinesVisibility="Horizontal"
                       GridLinesVisibility="Horizontal"
                       BackgroundColor="#1A1A1A">

            <syncfusion:SfDataGrid.DefaultStyle>
                <syncfusion:DataGridStyle HeaderRowBackground="#1A1A1A" 
                                  HeaderRowTextColor="#F5C842" 
                                  GridLineColor="#FFFFFF"/>
            </syncfusion:SfDataGrid.DefaultStyle>

            <syncfusion:SfDataGrid.Columns>
                <syncfusion:DataGridTextColumn MappingName="Id" HeaderText="Folio" Width="80">
                    <syncfusion:DataGridTextColumn.CellStyle>
                        <Style TargetType="syncfusion:DataGridCell">
                            <Setter Property="TextColor" Value="White" />
                        </Style>
                    </syncfusion:DataGridTextColumn.CellStyle>
                </syncfusion:DataGridTextColumn>

                <syncfusion:DataGridTextColumn MappingName="MesaId" HeaderText="Mesa" Width="80">
                    <syncfusion:DataGridTextColumn.CellStyle>
                        <Style TargetType="syncfusion:DataGridCell">
                            <Setter Property="TextColor" Value="White" />
                        </Style>
                    </syncfusion:DataGridTextColumn.CellStyle>
                </syncfusion:DataGridTextColumn>

                <syncfusion:DataGridTextColumn MappingName="Estado" HeaderText="Estatus" Width="120">
                    <syncfusion:DataGridTextColumn.CellStyle>
                        <Style TargetType="syncfusion:DataGridCell">
                            <Setter Property="TextColor" Value="#F5C842" />
                        </Style>
                    </syncfusion:DataGridTextColumn.CellStyle>
                </syncfusion:DataGridTextColumn>

                <syncfusion:DataGridTextColumn MappingName="Total" HeaderText="Total" Format="C2" Width="100">
                    <syncfusion:DataGridTextColumn.CellStyle>
                        <Style TargetType="syncfusion:DataGridCell">
                            <Setter Property="TextColor" Value="White" />
                        </Style>
                    </syncfusion:DataGridTextColumn.CellStyle>
                </syncfusion:DataGridTextColumn>

                <syncfusion:DataGridTextColumn MappingName="FechaHora" HeaderText="Fecha" Format="dd/MM/yyyy" Width="150">
                    <syncfusion:DataGridTextColumn.CellStyle>
                        <Style TargetType="syncfusion:DataGridCell">
                            <Setter Property="TextColor" Value="White" />
                        </Style>
                    </syncfusion:DataGridTextColumn.CellStyle>
                </syncfusion:DataGridTextColumn>
            </syncfusion:SfDataGrid.Columns>
        </syncfusion:SfDataGrid>
    </Grid>
</ContentPage>