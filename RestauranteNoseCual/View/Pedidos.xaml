<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:syncfusion="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
             xmlns:converters="clr-namespace:RestauranteNoseCual.Converters"
             x:Class="RestauranteNoseCual.View.Pedidos"
             Title="Historial de Pedidos"
             BackgroundColor="#121212">

    <ContentPage.Resources>
        <converters:EstadoColorConverter x:Key="EstadoColor"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- TÍTULO -->
        <Label Grid.Row="0"
               Text="MIS PEDIDOS"
               TextColor="#F5C842"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               Margin="20,20,20,8"/>

        <!-- FILTRO TIPO ENTREGA -->
        <Border Grid.Row="1"
                BackgroundColor="#1A1A1A"
                StrokeShape="RoundRectangle 12"
                Stroke="#333333"
                Margin="16,0,16,12"
                Padding="16,0"
                HeightRequest="52">
            <Picker x:Name="FiltroPicker"
                    Title="Filtrar por tipo de entrega"
                    TitleColor="#555555"
                    TextColor="White"
                    BackgroundColor="Transparent"
                    SelectedIndexChanged="OnFiltroChanged">
                <Picker.Items>
                    <x:String>Todos</x:String>
                    <x:String>Mesa</x:String>
                    <x:String>Para llevar</x:String>
                </Picker.Items>
            </Picker>
        </Border>

        <!-- GRID DE PEDIDOS -->
        <syncfusion:SfDataGrid Grid.Row="2"
                               x:Name="GridPedidos"
                               AutoGenerateColumnsMode="None"
                               HeaderGridLinesVisibility="Horizontal"
                               GridLinesVisibility="Horizontal"
                               BackgroundColor="#1A1A1A"
                               RowHeight="52">

            <syncfusion:SfDataGrid.DefaultStyle>
                <syncfusion:DataGridStyle HeaderRowBackground="#1A1A1A"
                                          HeaderRowTextColor="#F5C842"
                                          GridLineColor="#2A2A2A"/>
            </syncfusion:SfDataGrid.DefaultStyle>

            <syncfusion:SfDataGrid.Columns>

                <syncfusion:DataGridTextColumn MappingName="Id"
                                               HeaderText="Folio"
                                               Width="70">
                    <syncfusion:DataGridTextColumn.CellStyle>
                        <Style TargetType="syncfusion:DataGridCell">
                            <Setter Property="TextColor" Value="White"/>
                        </Style>
                    </syncfusion:DataGridTextColumn.CellStyle>
                </syncfusion:DataGridTextColumn>

                <syncfusion:DataGridTextColumn MappingName="MesaId"
                                               HeaderText="Mesa"
                                               Width="65">
                    <syncfusion:DataGridTextColumn.CellStyle>
                        <Style TargetType="syncfusion:DataGridCell">
                            <Setter Property="TextColor" Value="White"/>
                        </Style>
                    </syncfusion:DataGridTextColumn.CellStyle>
                </syncfusion:DataGridTextColumn>

                <syncfusion:DataGridTextColumn MappingName="NombreCliente"
                                               HeaderText="Cliente"
                                               Width="110">
                    <syncfusion:DataGridTextColumn.CellStyle>
                        <Style TargetType="syncfusion:DataGridCell">
                            <Setter Property="TextColor" Value="White"/>
                        </Style>
                    </syncfusion:DataGridTextColumn.CellStyle>
                </syncfusion:DataGridTextColumn>

                <syncfusion:DataGridTextColumn MappingName="TipoEntrega"
                                               HeaderText="Tipo"
                                               Width="90">
                    <syncfusion:DataGridTextColumn.CellStyle>
                        <Style TargetType="syncfusion:DataGridCell">
                            <Setter Property="TextColor" Value="#F5C842"/>
                        </Style>
                    </syncfusion:DataGridTextColumn.CellStyle>
                </syncfusion:DataGridTextColumn>

                <syncfusion:DataGridTemplateColumn HeaderText="Estatus"
                                   Width="100">
                    <syncfusion:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Margin="6,8">
                                <!-- Fondo con opacidad baja -->
                                <Border StrokeShape="RoundRectangle 6"
                        Stroke="Transparent"
                        BackgroundColor="{Binding Estado, Converter={StaticResource EstadoColor}}"
                        Opacity="0.2"/>
                                <!-- Texto encima con opacidad completa -->
                                <Label Text="{Binding Estado}"
                       TextColor="{Binding Estado, Converter={StaticResource EstadoColor}}"
                       FontSize="11"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
                            </Grid>
                        </DataTemplate>
                    </syncfusion:DataGridTemplateColumn.CellTemplate>
                </syncfusion:DataGridTemplateColumn>

                <syncfusion:DataGridTextColumn MappingName="Total"
                                               HeaderText="Total"
                                               Format="C2"
                                               Width="90">
                    <syncfusion:DataGridTextColumn.CellStyle>
                        <Style TargetType="syncfusion:DataGridCell">
                            <Setter Property="TextColor" Value="White"/>
                        </Style>
                    </syncfusion:DataGridTextColumn.CellStyle>
                </syncfusion:DataGridTextColumn>

                <syncfusion:DataGridTextColumn MappingName="FechaHora"
                                               HeaderText="Fecha"
                                               Format="dd/MM/yy HH:mm"
                                               Width="120">
                    <syncfusion:DataGridTextColumn.CellStyle>
                        <Style TargetType="syncfusion:DataGridCell">
                            <Setter Property="TextColor" Value="White"/>
                        </Style>
                    </syncfusion:DataGridTextColumn.CellStyle>
                </syncfusion:DataGridTextColumn>

                <!-- BOTÓN VER DETALLE -->
                <syncfusion:DataGridTemplateColumn HeaderText="Detalle"
                                                   Width="90">
                    <syncfusion:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Text="Ver 👁️"
                                    BackgroundColor="#F5C842"
                                    TextColor="#0D0D0D"
                                    FontSize="11"
                                    FontAttributes="Bold"
                                    CornerRadius="8"
                                    Margin="6,6"
                                    CommandParameter="{Binding .}"
                                    Clicked="OnVerDetalleClicked"/>
                        </DataTemplate>
                    </syncfusion:DataGridTemplateColumn.CellTemplate>
                </syncfusion:DataGridTemplateColumn>

            </syncfusion:SfDataGrid.Columns>
        </syncfusion:SfDataGrid>

    </Grid>
</ContentPage>