<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RestauranteNoseCual.View.SeleccionMesaPage"
             BackgroundColor="#0D0D0D"
             Title="Seleccionar Mesa">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0"
                             Padding="20,20,20,0"
                             Spacing="4">
            <Label Text="🪑 SELECCIONA UNA MESA"
                   TextColor="#F5C842"
                   FontSize="13"
                   FontAttributes="Bold"
                   CharacterSpacing="2"/>
            <Label Text="Toca una mesa libre para comenzar la orden"
                   TextColor="#666666"
                   FontSize="12"/>
        </VerticalStackLayout>

        <!-- Leyenda -->
        <HorizontalStackLayout Grid.Row="1"
                               Padding="20,16,20,8"
                               Spacing="20">
            <HorizontalStackLayout Spacing="8">
                <Border BackgroundColor="#2A4A2A"
                        StrokeShape="RoundRectangle 6"
                        Stroke="Transparent"
                        WidthRequest="20"
                        HeightRequest="20"/>
                <Label Text="Libre" TextColor="#888888" FontSize="12" VerticalOptions="Center"/>
            </HorizontalStackLayout>
            <HorizontalStackLayout Spacing="8">
                <Border BackgroundColor="#4A2A2A"
                        StrokeShape="RoundRectangle 6"
                        Stroke="Transparent"
                        WidthRequest="20"
                        HeightRequest="20"/>
                <Label Text="Ocupada" TextColor="#888888" FontSize="12" VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </HorizontalStackLayout>

        <!-- Grid de mesas -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout Padding="16,0,16,24">

                <!-- Indicador de carga -->
                <ActivityIndicator x:Name="Cargando"
                                   IsRunning="True"
                                   IsVisible="True"
                                   Color="#F5C842"
                                   Margin="0,40"/>

                <!-- CollectionView de mesas -->
                <CollectionView x:Name="ListaMesas"
                                IsVisible="False"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical"
                                         Span="3"
                                         HorizontalItemSpacing="10"
                                         VerticalItemSpacing="10"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 16"
                                    StrokeThickness="2"
                                    Padding="0"
                                    HeightRequest="110">
                                <Border.Triggers>
                                    <!-- Verde si está Libre -->
                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding Estado}"
                                                 Value="Libre">
                                        <Setter Property="BackgroundColor" Value="#1A2E1A"/>
                                        <Setter Property="Stroke" Value="#3A7A3A"/>
                                    </DataTrigger>
                                    <!-- Rojo si está Ocupada -->
                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding Estado}"
                                                 Value="Ocupada">
                                        <Setter Property="BackgroundColor" Value="#2E1A1A"/>
                                        <Setter Property="Stroke" Value="#7A3A3A"/>
                                    </DataTrigger>
                                </Border.Triggers>

                                <Grid RowDefinitions="*,Auto"
                                      Padding="10">
                                    <Label Grid.Row="0"
                                           Text="🪑"
                                           FontSize="36"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>

                                    <VerticalStackLayout Grid.Row="1" Spacing="2">
                                        <Label Text="{Binding Numero, StringFormat='Mesa {0}'}"
                                               TextColor="White"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               HorizontalOptions="Center"/>
                                        <Label Text="{Binding Estado}"
                                               FontSize="10"
                                               HorizontalOptions="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding Estado}"
                                                             Value="Libre">
                                                    <Setter Property="TextColor" Value="#3A7A3A"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding Estado}"
                                                             Value="Ocupada">
                                                    <Setter Property="TextColor" Value="#7A3A3A"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </VerticalStackLayout>

                                    <!-- Tap solo si está Libre -->
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnMesaSeleccionada"
                                                              CommandParameter="{Binding .}"/>
                                    </Grid.GestureRecognizers>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>