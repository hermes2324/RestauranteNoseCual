<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:syncfusion="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
             x:Class="RestauranteNoseCual.View.OrdenDetallePage"
             BackgroundColor="#121212"
             Title="Detalle de Orden">

    <Grid RowDefinitions="Auto,*,Auto">

        <Border Grid.Row="0"
                BackgroundColor="#1A1A1A"
                StrokeShape="RoundRectangle 16"
                Stroke="#2A2A2A"
                Margin="16,16,16,8"
                Padding="20,16">
            <Grid ColumnDefinitions="*,*"
                  RowDefinitions="Auto,Auto,Auto,Auto"
                  RowSpacing="8">
                <Label Grid.Row="0" Grid.Column="0" Text="Folio"
                       TextColor="#888888" FontSize="11"/>
                <Label Grid.Row="0" Grid.Column="1" x:Name="LblFolio"
                       TextColor="White" FontSize="13" FontAttributes="Bold"/>
                <Label Grid.Row="1" Grid.Column="0" Text="Cliente"
                       TextColor="#888888" FontSize="11"/>
                <Label Grid.Row="1" Grid.Column="1" x:Name="LblCliente"
                       TextColor="White" FontSize="13"/>
                <Label Grid.Row="2" Grid.Column="0" Text="Mesa"
                       TextColor="#888888" FontSize="11"/>
                <Label Grid.Row="2" Grid.Column="1" x:Name="LblMesa"
                       TextColor="White" FontSize="13"/>
                <Label Grid.Row="3" Grid.Column="0" Text="Tipo"
                       TextColor="#888888" FontSize="11"/>
                <Label Grid.Row="3" Grid.Column="1" x:Name="LblTipo"
                       TextColor="#F5C842" FontSize="13" FontAttributes="Bold"/>
            </Grid>
        </Border>

        <syncfusion:SfDataGrid Grid.Row="1"
                               x:Name="GridDetalle"
                               AutoGenerateColumnsMode="None"
                               GridLinesVisibility="Horizontal"
                               HeaderGridLinesVisibility="Horizontal"
                               BackgroundColor="#1A1A1A"
                               Margin="16,0">
            <syncfusion:SfDataGrid.DefaultStyle>
                <syncfusion:DataGridStyle HeaderRowBackground="#1A1A1A"
                                          HeaderRowTextColor="#F5C842"
                                          GridLineColor="#2A2A2A"/>
            </syncfusion:SfDataGrid.DefaultStyle>
            <syncfusion:SfDataGrid.Columns>
                <syncfusion:DataGridTextColumn MappingName="NombreProducto" HeaderText="Producto" Width="160">
                    <syncfusion:DataGridTextColumn.CellStyle>
                        <Style TargetType="syncfusion:DataGridCell">
                            <Setter Property="TextColor" Value="White"/>
                            <Setter Property="FontAttributes" Value="Bold"/>
                        </Style>
                    </syncfusion:DataGridTextColumn.CellStyle>
                </syncfusion:DataGridTextColumn>
                <syncfusion:DataGridTextColumn MappingName="Cantidad" HeaderText="Cant." Width="85">
                    <syncfusion:DataGridTextColumn.CellStyle>
                        <Style TargetType="syncfusion:DataGridCell">
                            <Setter Property="TextColor" Value="White"/>
                        </Style>
                    </syncfusion:DataGridTextColumn.CellStyle>
                </syncfusion:DataGridTextColumn>

                <syncfusion:DataGridTextColumn MappingName="PrecioUnitario" HeaderText="Precio" Format="C2" Width="85">
                    <syncfusion:DataGridTextColumn.CellStyle>
                        <Style TargetType="syncfusion:DataGridCell">
                            <Setter Property="TextColor" Value="White"/>
                        </Style>
                    </syncfusion:DataGridTextColumn.CellStyle>
                </syncfusion:DataGridTextColumn>
                <syncfusion:DataGridTextColumn MappingName="Subtotal" HeaderText="Subtotal" Format="C2" Width="90">
                    <syncfusion:DataGridTextColumn.CellStyle>
                        <Style TargetType="syncfusion:DataGridCell">
                            <Setter Property="TextColor" Value="#F5C842"/>
                            <Setter Property="FontAttributes" Value="Bold"/>
                        </Style>
                    </syncfusion:DataGridTextColumn.CellStyle>
                </syncfusion:DataGridTextColumn>
            </syncfusion:SfDataGrid.Columns>
        </syncfusion:SfDataGrid>

        <VerticalStackLayout Grid.Row="2" Spacing="0" Padding="0,0,0,24">
            <Border BackgroundColor="#1A1A1A"
                    StrokeShape="RoundRectangle 16"
                    Stroke="#F5C842"
                    Margin="16,8"
                    Padding="20,16">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="TOTAL" TextColor="#F5C842" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Label Grid.Column="1" x:Name="LblTotal" TextColor="#F5C842" FontSize="22" FontAttributes="Bold" VerticalOptions="Center"/>
                </Grid>
            </Border>

            <Button x:Name="BtnCobrar"
                    Text="💰 COBRAR"
                    IsVisible="False" 
                    Clicked="OnCobrarClicked"
                    BackgroundColor="#F5C842"
                    TextColor="#0D0D0D"
                    FontAttributes="Bold"
                    FontSize="15"
                    HeightRequest="54"
                    CornerRadius="12"
                    Margin="16,0"/>

            <Button x:Name="BtnCancelar"
                    Text="❌ CANCELAR PEDIDO"
                    IsVisible="False"
                    Clicked="OnCancelarClicked"
                    BackgroundColor="#FF4444"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="15"
                    HeightRequest="54"
                    CornerRadius="12"
                    Margin="16,0"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>